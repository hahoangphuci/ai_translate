# Copy to backend/.env and fill values for local development
# Do NOT commit real secrets to the repository.

# App keys
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=jwt-secret-key

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI used for OAuth callbacks (use 127.0.0.1 for local dev)
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/api/auth/google/callback

# Database: default uses MySQL. For quick local dev you can use sqlite:///<relative-path>
# Example MySQL: mysql+pymysql://root:password@127.0.0.1:3306/ai_translation
# Example SQLite (dev): sqlite:///../instance/translation.db
DATABASE_URL=mysql+pymysql://root:@localhost:3306/ai_translation

# Payment (sepay)
SEPAY_API_KEY=
# Optional: webhook auth key (defaults to SEPAY_API_KEY)
SEPAY_WEBHOOK_API_KEY=
# Kept for backward-compatibility with older setups (not used by current code)
SEPAY_SECRET=
SEPAY_BASE_URL=https://my.sepay.vn
SEPAY_HISTORY_ENDPOINT=/userapi/transactions/list

# Payment polling + transfer content
NAME_WEB=AITRANS
PAYMENT_TRANSFER_KEYWORD=NAPTOKEN
PAYMENT_XOR_KEY=0x5EAFB
PAYMENT_EXPIRE_MINUTES=60
PAYMENT_POLL_TX_LIMIT=20

# Optional QR info (VietQR)
PAYMENT_BANK_CODE=MB
PAYMENT_BANK_ACCOUNT=
PAYMENT_BANK_ACCOUNT_NAME=

# Optional: use SePay QR image generator instead of img.vietqr.io
# Docs: https://qr.sepay.vn/
# Example (fill acc/bank accordingly):
# SEPAY_QR_TEMPLATE_URL=https://qr.sepay.vn/img?acc={account_number}&bank={bank_code}&amount={amount}&des={content}&template=compact
SEPAY_QR_TEMPLATE_URL=

# Token economy
FREE_TRIAL_TOKENS=5000

# AI provider keys
OPENAI_API_KEY=
DEEPL_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
AI_PROVIDER=openrouter
AI_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
TRANSLATION_PROVIDER_DEFAULT=google

# OCR (Image -> Text)
# Windows example: TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
TESSERACT_CMD=
# Default OCR languages for Tesseract (use '+' to combine)
OCR_LANGS_DEFAULT=eng+vie

# PDF translation uses the DOCX pipeline (PDF -> DOCX -> translate -> PDF)
# Legacy PDF_TRANSLATION_PIPELINE is ignored; only docx pipeline is supported.

# PDF -> DOCX converter: pdf2docx | word | adobe
PDF_DOCX_CONVERTER=pdf2docx

# DOCX -> PDF engine: auto | docx2pdf | libreoffice
PDF_DOCX_EXPORT_ENGINE=auto

# Keep intermediate DOCX files for debugging
PDF_DOCX_KEEP_INTERMEDIATE=0

# Layout mode: auto | academic | conservative
# auto = detect journal/paper vs general PDF (invoice, letter, report...)
# academic = regional title/abstract/body profiles (best for Springer/IEEE papers)
# conservative = keep pdf2docx layout, sync paragraph properties from source
PDF_DOCX_LAYOUT_MODE=auto

# Preserve each PDF line/paragraph — do not merge lines or insert inferred spaces (default on)
PDF_DOCX_PRESERVE_LINES=1
# Keep Symbol/Wingdings glyphs from PDF (0 = map to +/• in Times New Roman, recommended)
PDF_DOCX_PRESERVE_SYMBOL_GLYPHS=0
PDF_DOCX_UNIFY_FONTS=1
# Set to 1 only for legacy academic prose merge (collapses soft line wraps before translate)
PDF_DOCX_COLLAPSE_SOFT_BREAKS=0

# Layout recovery: copy paragraph properties from pre-translation DOCX (safe mode)
PDF_DOCX_MIRROR_LAYOUT=1
PDF_DOCX_LAYOUT_SYNC=1
PDF_DOCX_PDF_FORMAT_SYNC=0
PDF_DOCX_PDF_BOLD_SYNC=1
PDF_DOCX_PDF_ALIGN_SYNC=0
PDF_DOCX_TABLE_SYNC=1
PDF_DOCX_HEADER_FOOTER_SYNC=1
PDF_DOCX_MERGE_FRAGMENTS=0
PDF_DOCX_FIX_ANOMALIES=0
PDF_DOCX_STRIP_NOISE=1
PDF_DOCX_NORMALIZE_ALIGN=1
PDF_DOCX_NORMALIZE_INDENTS=1
PDF_DOCX_FORCE_BODY_JUSTIFY=1
PDF_DOCX_SANITIZE_MERGE_FRAGMENTS=1
PDF_DOCX_PDF_GEOMETRY_PROFILE=1
PDF_DOCX_REGIONAL_LAYOUT=1
PDF_DOCX_ACADEMIC_LAYOUT=0
# Academic papers: merge pdf2docx word runs + collapse soft line wraps (recommended)
PDF_DOCX_ACADEMIC_MERGE_LINES=1
PDF_DOCX_FONT_FIT=0
PDF_DOCX_SANITIZE_FORCE_LEFT=0

# Strict mode: fail if scan OCR cannot create searchable PDF
PDF_SCAN_OCR_STRICT=0

# PDF cleanup controls (used by scan OCR + cleaning stage)
PDF_CLEAN_NORMALIZE_ROTATION=1
PDF_CLEAN_AUTOROTATE=1
PDF_CLEAN_DESKEW=1
PDF_CLEAN_ENHANCE=1
PDF_CLEAN_RENDER_DPI=250

# Translation guard for DOCX (skip URL/DOI/reference/formula/code)
DOCX_TRANSLATION_GUARD=1

# Layout recovery for long table cells
DOCX_TABLE_SHRINK=0
DOCX_TABLE_SHRINK_LEN=140
DOCX_TABLE_SHRINK_MIN_PT=8
